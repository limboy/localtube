{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalTube",
  "version": "0.7.0",
  "identifier": "localtube.me.limboy",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../src-web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalTube",
        "hiddenTitle": true,
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 275,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self' https://*; frame-src 'self' https://www.youtube.com https://youtube.com; img-src 'self' data: https://*; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*; style-src 'self' 'unsafe-inline' https://*;  connect-src 'self' ipc: tauri: http: https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "13.0",
      "exceptionDomain": "",
      "frameworks": [],
      "signingIdentity": "Developer ID Application: LI ZHONG (5P9ZHW7578)"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFEOUEyRUQyNzA3RTZCNjYKUldSbWEzNXcwaTZhcmEwaWEvK3RVbmFnSFVUT291N3ladTR3VXFvMFhnU2FROWpaUHY4UlVYZ3EK",
      "endpoints": [
        "https://releases.limstack.com/localtube/latest.json"
      ]
    }
  }
}